# Application
APP_NAME=envguard
APP_ENV=production
APP_DEBUG=false

# Server
PORT=8000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@db-host:5432/my_database
REDIS_URL=redis://redis-host:6379/0

# Auth / Security
JWT_SECRET=super-secret-jwt-key
JWT_EXPIRY_HOURS=24

# Third-party services
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SOME_NEW_KEY=

# Misc
LOG_LEVEL=info
NODE_ENV=production
